   "source": [
    "class Student:\n",
    "  def __init__(self, age):\n",
    "    self.__age = age  ## __age: 私有属性，不能直接修改\n",
    "\n",
    "  def set_age(self, age):\n",
    "    self.__age = age\n",
    "\n",
    "  def get_age(self):\n",
    "    return self.__age\n",
    "\n",
    "stu1 = Student(10)\n",
    "stu1.set_age(20)\n",
    "print('stu1:', stu1.get_age())"
   ]
  }
 ],
