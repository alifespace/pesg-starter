   "source": [
    "from pathlib import Path\n",
    "\n",
    "file1 = Path('aa.txt')\n",
    "try:\n",
    "  \n",
    "  content = file1.read_text(encoding='utf-8')\n",
    "  words = content.split()\n",
    "  num_words = len(words)\n",
    "  print(f'文件{file1}共有单词{num_words}个')\n",
    "except FileNotFoundError as e:\n",
    "  print(f'找不到指定文件{file1}')"
   ]
  }
