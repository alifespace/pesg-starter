    "def mySum(*args):   # 所有实参组成args这个元组\n",
    "  sum1 = 0\n",
    "  for i in args:\n",
    "    sum1 +=i\n",
    "  print(sum1)\n",
    "  return sum1\n",
    "\n",
    "mySum(1, 2, 3)\n",
    "mySum(1, 2, 3, 4)\n"
   ]
